# PeanutGallery Configuration

# OpenRouter API Key for high-level reasoning and jokes
OPENROUTER_API_KEY=your_openrouter_key_here

# GetStream Credentials for WebRTC Transport
STREAM_API_KEY=your_stream_key_here
STREAM_API_SECRET=your_stream_secret_here

# SQLite Database Location
DATABASE_URL=sqlite:///./peanutgallery.db

# Kokoro TTS Configuration (Optional: Remote Server)
# If left empty, will attempt local inference
KOKORO_SERVER_URL=

# Hardware Acceleration
# Set to 'cuda' if you have an NVIDIA GPU, else 'cpu'
DEVICE=cpu
